# CycloneOS 環境變數範本
# 複製此檔案為 .env.local 並填入你的值

# --- Google Drive ---
GOOGLE_DRIVE_EMAIL_PERSONAL=your-email@gmail.com
GOOGLE_DRIVE_EMAIL_SCHOOL=your-email@school.edu.tw
NEXT_PUBLIC_GDRIVE_EMAIL=your-email@gmail.com

# --- Notion ---
NOTION_API_KEY=
NOTION_TASKS_DB_ID=
NOTION_SOCIAL_DATABASE_ID=

# --- LLM Provider ---
# LLM_PROVIDER=claude|codex|openai
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o

# --- Gmail ---
# GMAIL_CLIENT_ID=
